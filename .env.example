# LLM
GROQ_API_KEY=your_groq_key_here

# Slack
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_SIGNING_SECRET=your-signing-secret

# Database
# For Supabase/Cloud Postgres (Overrides individual fields above if set)
# Ensure the protocol is postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres.your-project:your-password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# Local Postgres Fallback (Used if DATABASE_URL is not set)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=webhook_server
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
