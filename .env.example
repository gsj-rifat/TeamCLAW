# LLM
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Slack
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_SIGNING_SECRET=your-signing-secret
TARGET_CHANNEL_ID=C0123456789

# Database (required — PostgreSQL via Supabase or local)
DATABASE_URL=postgresql+asyncpg://postgres.your-project:your-password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Optional: override dashboard tenant scope (defaults to default tenant)
# DASHBOARD_TENANT_ID=00000000-0000-0000-0000-000000000000

# Jira (optional)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-jira-token
JIRA_PROJECT_KEY=ENG

# Tenant defaults
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000000
